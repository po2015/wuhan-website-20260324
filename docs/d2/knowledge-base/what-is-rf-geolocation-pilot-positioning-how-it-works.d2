direction: right

classes: {
  light_blue: {
    shape: rectangle
    width: 210
    style.fill: "#EFF6FF"
    style.stroke: "#60A5FA"
    style.font-color: "#0F172A"
    style.font-size: 17
  }
  dark_blue: {
    shape: rectangle
    width: 210
    style.fill: "#0F304B"
    style.stroke: "#7ED0FF"
    style.font-color: "#FFFFFF"
    style.font-size: 17
  }
  gold: {
    shape: rectangle
    width: 210
    style.fill: "#FFFBEB"
    style.stroke: "#F59E0B"
    style.font-color: "#0F172A"
    style.font-size: 17
  }
}

signal: "Drone-related RF link\n\nControl, telemetry,\nvideo, or Remote ID"
signal.class: light_blue

sensors: "Distributed receivers\n\nCapture the same\nsignal event"
sensors.class: dark_blue

measure: "Measurement engine\n\nAOA, TDOA, or hybrid"
measure.class: gold

estimate: "Location estimate\n\nPoint, area, or\nconfidence region"
estimate.class: dark_blue

operator: "Map output\n\nCue another sensor\nor response team"
operator.class: light_blue

signal -> sensors: detect
sensors -> measure: compare
measure -> estimate: fuse
estimate -> operator: display
