direction: right

classes: {
  stack: {
    label: ""
    style.fill: "transparent"
    style.stroke: "transparent"
  }
  sensor_blue: {
    shape: rectangle
    width: 200
    height: 120
    style.fill: "#EFF6FF"
    style.stroke: "#60A5FA"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  sensor_gold: {
    shape: rectangle
    width: 200
    height: 120
    style.fill: "#FFFBEB"
    style.stroke: "#F59E0B"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  hero: {
    shape: hexagon
    width: 300
    height: 170
    style.fill: "#ECFEFF"
    style.stroke: "#06B6D4"
    style.font-color: "#0F172A"
    style.font-size: 22
  }
  output_green: {
    shape: rectangle
    width: 200
    height: 120
    style.fill: "#ECFDF5"
    style.stroke: "#10B981"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
}

input_stack: {
  class: stack
  direction: down

  sensor_a: "SENSOR A\n\nFacility edge"
  sensor_a.class: sensor_blue

  sensor_b: "SENSOR B\n\nCity zone"
  sensor_b.class: sensor_gold

  sensor_c: "SENSOR C\n\nWide-area watch"
  sensor_c.class: sensor_blue
}

hero_panel: "SPECTRUM MONITORING\n\nMeasure RF activity\nacross time, band,\nand location"
hero_panel.class: hero

output_stack: {
  class: stack
  direction: down

  occupancy: "OCCUPANCY\n\nWhen bands are busy"
  occupancy.class: output_green

  anomaly: "ANOMALIES\n\nWhat changed or\nlooks unusual"
  anomaly.class: sensor_gold
}

input_stack.sensor_a -> hero_panel: RF data
input_stack.sensor_b -> hero_panel: RF data
input_stack.sensor_c -> hero_panel: RF data
hero_panel -> output_stack.occupancy: history
hero_panel -> output_stack.anomaly: alert
