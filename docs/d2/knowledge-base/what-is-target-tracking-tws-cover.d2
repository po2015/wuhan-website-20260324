direction: right

classes: {
  blue_card: {
    shape: rectangle
    width: 190
    height: 160
    style.fill: "#EFF6FF"
    style.stroke: "#60A5FA"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  gold_card: {
    shape: rectangle
    width: 190
    height: 160
    style.fill: "#FFFBEB"
    style.stroke: "#F59E0B"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  green_card: {
    shape: rectangle
    width: 190
    height: 160
    style.fill: "#ECFDF5"
    style.stroke: "#10B981"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  hero: {
    shape: hexagon
    width: 210
    height: 170
    style.fill: "#F8FAFC"
    style.stroke: "#334155"
    style.font-color: "#0F172A"
    style.font-size: 20
  }
}

search_task: "SEARCH\n\nScan the wider\nscene"
search_task.class: blue_card

hero_panel: "TWS\n\nSearch and track\nat the same time"
hero_panel.class: hero

update_task: "UPDATE\nTRACKS\n\nRefresh known\ntargets"
update_task.class: gold_card

predict_task: "PREDICT\n\nEstimate where the\ntrack goes next"
predict_task.class: green_card

search_task -> hero_panel: detect
hero_panel -> update_task: maintain
update_task -> predict_task: next revisit
