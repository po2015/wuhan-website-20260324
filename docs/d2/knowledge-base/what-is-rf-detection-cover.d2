direction: down

classes: {
  stack: {
    label: ""
    style.fill: "transparent"
    style.stroke: "transparent"
  }
  hero: {
    shape: hexagon
    width: 300
    height: 160
    style.fill: "#E0F2FE"
    style.stroke: "#0EA5E9"
    style.font-color: "#0F172A"
    style.font-size: 22
  }
  source_blue: {
    shape: rectangle
    width: 210
    height: 120
    style.fill: "#EFF6FF"
    style.stroke: "#93C5FD"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  source_gold: {
    shape: rectangle
    width: 210
    height: 120
    style.fill: "#FFFBEB"
    style.stroke: "#FCD34D"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  source_green: {
    shape: rectangle
    width: 210
    height: 120
    style.fill: "#F0FDF4"
    style.stroke: "#86EFAC"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  output_purple: {
    shape: rectangle
    width: 210
    height: 120
    style.fill: "#FAF5FF"
    style.stroke: "#D8B4FE"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
}

signals: {
  class: stack
  direction: right

  controller: "CONTROLLER LINK\n\nPilot commands or\ntelemetry traffic"
  controller.class: source_blue

  remote_id: "REMOTE ID\n\nBroadcast identity\nand position data"
  remote_id.class: source_gold

  wireless: "OTHER RF ACTIVITY\n\nWi-Fi, Bluetooth,\nor unknown emitters"
  wireless.class: source_green
}

sensor: "RF DETECTION\n\nListen for wireless\nsignals and analyze\npatterns in the air"
sensor.class: hero

answers: {
  class: stack
  direction: right

  band: "BAND\n\nWhich frequency\nrange is active?"
  band.class: output_purple

  bearing: "DIRECTION\n\nWhere might the\nsignal be coming from?"
  bearing.class: output_purple

  type: "SIGNAL CLUES\n\nWhat kind of\ntransmitter is it?"
  type.class: output_purple
}

signals.controller -> sensor: uplink
signals.remote_id -> sensor: broadcast
signals.wireless -> sensor: emissions

sensor -> answers.band: measure
sensor -> answers.bearing: estimate
sensor -> answers.type: classify
