direction: right

classes: {
  compare_blue: {
    shape: rectangle
    width: 250
    height: 280
    style.fill: "#EFF6FF"
    style.stroke: "#60A5FA"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  compare_gold: {
    shape: rectangle
    width: 250
    height: 280
    style.fill: "#FFFBEB"
    style.stroke: "#F59E0B"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
  compare_green: {
    shape: rectangle
    width: 250
    height: 280
    style.fill: "#ECFDF5"
    style.stroke: "#10B981"
    style.font-color: "#0F172A"
    style.font-size: 18
  }
}

utm: "UTM\n\nBroad concept for\ndigital drone traffic\ncoordination.\n\nFocus: planning,\napprovals, shared data,\nconflict management."
utm.class: compare_blue

uspace: "U-SPACE\n\nEuropean framework for\ndesignated drone airspace.\n\nFocus: named services,\nprovider roles, and\nregulated workflows."
uspace.class: compare_gold

atc: "TRADITIONAL ATC\n\nConventional aviation\nmanagement for crewed\noperations.\n\nFocus: controller services,\nstructured separation,\nand voice-heavy control."
atc.class: compare_green
